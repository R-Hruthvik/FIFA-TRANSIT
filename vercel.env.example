# VERCEL DEPLOYMENT ENVIRONMENT VARIABLES TEMPLATE
# Copy these values into your Vercel Project Settings -> Environment Variables.
# Make sure to select "Production", "Preview", and "Development" scopes where appropriate.

# =============================================================================
# DATABASE (Required)
# =============================================================================
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=stadium_ops

# =============================================================================
# AUTHENTICATION (Required)
# =============================================================================
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=YOUR_SECURE_NEXTAUTH_SECRET
AUTH_SECRET=YOUR_SECURE_NEXTAUTH_SECRET

# Set to your Vercel production domain (e.g. https://stadiumflow.vercel.app)
NEXTAUTH_URL=https://<your-project>.vercel.app

# Google OAuth Credentials (OAuth origins and redirect URIs must be updated with your Vercel domain)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# =============================================================================
# AI PROVIDERS (Required for AI Features)
# =============================================================================
GEMINI_API_KEY=your-gemini-api-key
NVIDIA_NIM_API_KEY=your-nvidia-nim-api-key

# =============================================================================
# MAPS & WEATHER (Required for transit routing and weather)
# =============================================================================
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
OPENWEATHER_API_KEY=your-openweather-api-key

# =============================================================================
# SCHEDULER & SECURITY
# =============================================================================
# Generate with: openssl rand -base64 32
CRON_SECRET=your-cron-secret
