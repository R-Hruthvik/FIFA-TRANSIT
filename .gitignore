# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# python
__pycache__/
*.pyc
*.pyo

# vault / session data
vault/

# local-only skill files
.claude/


# local ignores
build-output.txt
*.diff
.superpowers/
.opencode/
.clinerules/

# temporary build files
tmp*
*.crt
*.rsa
*.pem
*.key
**.node

# Playwright / MCP artifacts
.playwright-mcp/
playwright-report/

# audit screenshots
*audit.png

# temp files from local commands
2026-07-17-*

# .gstack
.gstack/

# graphify output
graphify-out/

# txt files
*.txt

# user ideas
usr-ideas/

# all markdown except README
*.md
!README.md
